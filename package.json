{
  "name": "wylo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w packages/shared",
    "web": "npm run dev -w apps/web",
    "backend": "npm run dev -w apps/backend",
    "dev:all": "npm run dev -w apps/backend & npm run dev -w apps/web",
    "postinstall": "npm run build:shared",
    "lint": "npm run lint -w apps/web",
    "ci": "npm run lint && npm run build -w apps/backend && npm run build -w apps/web"
  },
  "engines": {
    "node": ">=18"
  }
}
