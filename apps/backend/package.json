{
  "name": "@wylo/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auth:generate": "npx @better-auth/cli generate --output ./src/db/schemas/auth-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:reset": "npx drizzle-kit push --force",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@wylo/shared": "*",
    "better-auth": "^1.5.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.5.0-beta.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
