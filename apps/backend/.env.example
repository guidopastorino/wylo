# Better Auth secret (32+ chars, e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=<your-better-auth-secret>

# Public origin where /api/auth lives (frontend/proxy origin)
BETTER_AUTH_URL=http://localhost:3000

# Frontend URL (for CORS / trustedOrigins)
FRONTEND_URL=http://localhost:3000

# Backend Express server port
PORT=5000

# Database connection string (adjust for prod)
DATABASE_URL=postgres://wylo:wylo@localhost:5432/wylo

# OAuth – GitHub
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>

# OAuth – Slack
SLACK_CLIENT_ID=<your-slack-client-id>
SLACK_CLIENT_SECRET=<your-slack-client-secret>

# OAuth – Vercel
VERCEL_CLIENT_ID=<your-vercel-client-id>
VERCEL_CLIENT_SECRET=<your-vercel-client-secret>